# ==================================================================
# .dockerignore for Spring Boot GraalVM Native Image Project
# ==================================================================

# Build outputs and target directories
target/
build/
out/
bin/
dist/
*.jar
*.war
*.ear

# IDE files and configurations
.idea/
.vscode/
*.iml
*.ipr
*.iws
.project
.classpath
.settings/
.metadata/
.recommenders/
.loadpath
.externalToolBuilders/

# Eclipse specific
.apt_generated
.apt_generated_test
.factorypath
.buildpath
.target
.tern-project
.texlipse
.springBeans
.sts4-cache

# IntelliJ IDEA specific
*.iml
*.ipr
*.iws
.idea/
out/

# NetBeans specific
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/

# Visual Studio Code
.vscode/
*.code-workspace

# Version control
.git/
.gitignore
.gitattributes
.gitmodules
.hg/
.hgignore
.svn/

# Operating System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.#*
#*#

# Log files
*.log
logs/
log/
*.log.*
*.out

# Test outputs
target/test-classes/
target/surefire-reports/
target/failsafe-reports/
target/jacoco-reports/
target/coverage-reports/

# Documentation and README files (optional - remove if needed in image)
README.md
README.txt
CHANGELOG.md
CONTRIBUTING.md
LICENSE
LICENSE.txt
docs/
documentation/
*.md

# Docker related files (don't include in build context)
Dockerfile
docker-compose.yml
docker-compose.yaml
docker-compose.*.yml
docker-compose.*.yaml
.dockerignore

# Environment and configuration files
.env
.env.local
.env.development
.env.test
.env.production
.env.staging
*.env
secrets/
config/local/

# Database files
*.db
*.sqlite
*.sqlite3
h2/
hsqldb/

# Cache directories
.cache/
.npm/
.yarn/
.m2/repository/

# Backup files
*.bak
*.backup
*~

# JVM crash logs
hs_err_pid*
core.*


# Performance and profiling
*.hprof
*.prof
*.jfr

# Security sensitive files
*.key
*.pem
*.p12
*.jks
*.keystore
*.truststore
keystore/
certificates/

# Test data and fixtures
test-data/
fixtures/
mock-data/

# Kubernetes and deployment files (optional)
k8s/
kubernetes/
helm/
deployment/
manifests/

# CI/CD files (optional - remove if needed for build info)
.github/
.gitlab-ci.yml
.travis.yml
.circleci/
Jenkinsfile
azure-pipelines.yml

# Keep essential files (use ! to negate ignore)
!src/
!pom.xml
!*.properties
!*.yml
!*.yaml
!*.xmlyour files here
