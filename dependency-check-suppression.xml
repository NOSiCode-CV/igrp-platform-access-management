    <!--
        OWASP Dependency-Check suppressions — failBuildOnCVSS=7 (High/Critical fails).
        Every suppressed entry has a <notes> block with:
          - Why the CVE does not apply to this project
          - Review date
        Run `mvn dependency-check:check` after any dependency bump to catch new CVEs.
    -->

    <!-- ============================================================
         cv.igrp.framework.filemanager:minio:0.1.0-beta.4
         CPE false positive: dependency-check matches the IGRP wrapper's
         version "0.1.0-beta.4" against MinIO SERVER CVEs by extracting
         "0.1.0.4". The wrapper is a thin client adapter; none of these
         CVEs target the MinIO Java SDK or any client code path.
         Reviewed: 2026-05-22
    ============================================================ -->
    <suppress>
        <notes><![CDATA[
        IGRP MinIO wrapper falsely matched against MinIO server CPEs.
        Wrapper version 0.1.0-beta.4 is not MinIO server 0.1.0.4.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/cv\.igrp\.framework\.filemanager/minio@.*$</packageUrl>
        <cpe>cpe:/a:minio:minio</cpe>
    </suppress>

    <!-- ============================================================
         com.google.protobuf:protobuf-java:3.25.9
         CVE-2026-0994 fix is in protobuf-java 4.x. We cannot bump to
         4.x without breaking k8s client-java and other transitives
         that depend on the protobuf 3.x ABI. We track 3.25.x patches
         (currently latest: 3.25.9). Risk: parsing untrusted protobuf
         messages — we don't accept protobuf from external callers.
         Reviewed: 2026-05-22
    ============================================================ -->
    <suppress>
        <notes><![CDATA[
        Fix only in protobuf-java 4.x (API-breaking). Project does not
        deserialize protobuf from untrusted input. Tracking 3.25.x.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-java@3\.25\..*$</packageUrl>
        <cve>CVE-2026-0994</cve>
    </suppress>

    <!-- ============================================================
         io.opentelemetry.semconv:opentelemetry-semconv(-incubating):1.41.1
         CVE-2026-39882 / CVE-2026-39883 affect ALL versions of the
         semantic-convention library and have no upstream fix yet.
         These are constants/enums only — no runtime parsing code path
         is exposed to attackers.
         Reviewed: 2026-05-22; recheck after each otel BOM bump.
    ============================================================ -->
    <suppress>
        <notes><![CDATA[
        opentelemetry-semconv is constant definitions only; no exploitable
        code path. No upstream patch as of 1.41.1.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.opentelemetry\.semconv/opentelemetry-semconv(-incubating)?@.*$</packageUrl>
        <cve>CVE-2026-39882</cve>
        <cve>CVE-2026-39883</cve>
        <cve>CVE-2026-29181</cve>
    </suppress>

