{
  "type": "controller",
  "name": "AuthAudit",
  "module": "oauth_server",
  "description": "OAuth2 authorization server audit log",
  "basePath": "api",
  "actions": [
    {
      "actionName": "listAuthAuditLogs",
      "path": "audit",
      "method": "GET",
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "type": "AuthAuditDTO",
                "name": "data",
                "collectionType": "list",
                "objectType": "dto",
                "module": "oauth_server"
              }
            }
          }
        }
      }
    },
    {
      "actionName": "listAuthAuditLogsByUser",
      "path": "audit/user/{username}",
      "method": "GET",
      "responses": {
        "200": {
          "content": {
            "application/json": {
              "schema": {
                "type": "AuthAuditDTO",
                "name": "data",
                "collectionType": "list",
                "objectType": "dto",
                "module": "oauth_server"
              }
            }
          }
        }
      },
      "pathVariables": [
        {"name": "username", "type": "string", "isRequired": true}
      ]
    }
  ],
  "id": "oauth-server-controller-audit"
}
