# =============================================================================
# Core application
# =============================================================================
# Active Spring profile. Drives which application-<profile>.properties is
# layered on top. Common values: development, staging, production, basic-auth.
SPRING_PROFILES_ACTIVE=development
# HTTP port the embedded Tomcat listens on.
SERVICE_PORT=8080
# Override the auto-derived Spring application name (used by Eureka, log MDC,
# OTel resource attributes). Leave commented to keep the default.
# SPRING_APPLICATION_NAME=igrp-access-management


# =============================================================================
# Database (PostgreSQL) [required]
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=db_igrp_iam
POSTGRES_USER=postgres
POSTGRES_PASSWORD=1234
# Optional overrides if the JDBC URL or credentials differ from POSTGRES_*.
# DATABASE_URL=jdbc:postgresql://localhost:5432/db_igrp_iam
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=1234


# =============================================================================
# Resource server — JWT validation [required]
# =============================================================================
# Issuer URL of the OAuth2 IdP whose tokens are accepted by /api/**. Must
# match the `iss` claim of every Bearer JWT presented to the API.
AUTH_JWT_ISSUER=https://api.example.cv/igrp-access-management


# =============================================================================
# Authorization Server — token issuance [required when issuing tokens locally]
# =============================================================================
# Issuer URL the local Spring Authorization Server stamps into issued JWTs.
# In production set the public-facing URL; behind a TLS-terminating proxy
# `server.forward-headers-strategy=framework` lets Spring infer https:// for
# you if left blank.
IGRP_OAUTH_ISSUER=https://api.example.cv/igrp-access-management

# Primary RSA key pair used to sign JWTs. Accepts classpath:keys/*.pem or an
# absolute filesystem path. The seeded defaults below are dev-only.
IGRP_OAUTH_PUBLIC_KEY=classpath:keys/public.pem
IGRP_OAUTH_PRIVATE_KEY=classpath:keys/private.pem
# JWK `kid` claim for the primary key.
IGRP_OAUTH_KEY_ID=igrp-oauth-key

# OWASP A02 — optional secondary key for zero-downtime rotation.
# Leave all three blank to keep running on just the primary key. Populate all
# three (kid + public + private) to roll a new key without invalidating
# in-flight tokens (RotatingJWKSource publishes both in the JWKS so resource
# servers accept tokens signed by either during the overlap window).
IGRP_OAUTH_SECONDARY_KEY_ID=
IGRP_OAUTH_SECONDARY_PUBLIC_KEY=
IGRP_OAUTH_SECONDARY_PRIVATE_KEY=


# =============================================================================
# Default seeded OAuth2 client (DefaultOAuthClientBootstrap) [optional]
# =============================================================================
# Skipped automatically when IGRP_OAUTH_DEFAULT_CLIENT_SECRET is blank.
IGRP_OAUTH_DEFAULT_CLIENT_ID=igrp-access-management
IGRP_OAUTH_DEFAULT_CLIENT_SECRET=
# Token lifetimes (seconds). Defaults are 1h / 24h / 5min.
IGRP_OAUTH_DEFAULT_CLIENT_ACCESS_TOKEN_TTL=3600
IGRP_OAUTH_DEFAULT_CLIENT_REFRESH_TOKEN_TTL=86400
IGRP_OAUTH_DEFAULT_CLIENT_AUTHORIZATION_CODE_TTL=300
# Registered redirect URIs for the seeded client (used in authorization_code
# flow). Add additional URIs after bootstrap through PUT /api/clients/{id}.
IGRP_OAUTH_DEFAULT_CLIENT_REDIRECT_URI=https://app.example.cv/callback
# OIDC RP-initiated logout — where to send users after /connect/logout.
IGRP_OAUTH_DEFAULT_CLIENT_POST_LOGOUT_REDIRECT_URI=https://app.example.cv/logged-out


# =============================================================================
# External IdP federation (OAuth2 login) [optional]
# =============================================================================
# Whether to enable upstream IdP login (Keycloak, WSO2, Autentika, etc.).
IGRP_OAUTH_EXTERNAL_IDP_ENABLED=true
IGRP_OAUTH_EXTERNAL_IDP_CLIENT_ID=
IGRP_OAUTH_EXTERNAL_IDP_CLIENT_SECRET=
# Issuer URL of the upstream IdP — Spring discovers JWKs, /authorize, /token
# via OIDC discovery on this URL.
IGRP_OAUTH_EXTERNAL_IDP_ISSUER_URI=https://<your_idp_instance>/realms/igrp
# Callback URI the upstream IdP must redirect to. Leave the placeholder
# template to let Spring fill in baseUrl + registrationId at runtime.
IGRP_OAUTH_EXTERNAL_IDP_REDIRECT_URI={baseUrl}/login/oauth2/code/{registrationId}


# =============================================================================
# OIDC RP-initiated logout cascade [optional]
# =============================================================================
# When true (default), /connect/logout 302s to the upstream IdP's
# end_session_endpoint after killing the local session/cookies so the user's
# SSO cookie at the IdP is invalidated too. Without this hop, the next
# /oauth2/authorize call silently re-authenticates against the IdP's still-
# active SSO session and Spring AS hands back a fresh code without prompting.
# Set to false to keep logout local-only (e.g. when multiple apps share the
# IdP and you don't want logout from one to drop the others).
IGRP_OAUTH_LOGOUT_CASCADE=true
# Spring registration id of the upstream IdP — match the suffix on the
# spring.security.oauth2.client.registration.<id>.* properties.
IGRP_OAUTH_EXTERNAL_IDP_REGISTRATION_ID=external-idp


# =============================================================================
# OWASP A04/A07 — Federated login gates [recommended in production]
# =============================================================================
# Reject logins whose upstream ID Token does not carry email_verified: true.
# Set to false only when integrating a legacy IdP that never sets this claim.
IGRP_OAUTH_REQUIRE_EMAIL_VERIFIED=true
# Comma-separated list of allowed email domains (e.g. igrp.cv,nosi.cv).
# Leave blank to accept all domains (open federation).
IGRP_OAUTH_ALLOWED_EMAIL_DOMAINS=
# Comma-separated ACR values the upstream ID Token must carry (e.g.
# pwd,cmdcv,cni). Leave blank to accept any ACR (no step-up enforcement).
IGRP_OAUTH_REQUIRED_ACR_VALUES=


# =============================================================================
# OWASP A01/A05 — CORS [required in non-local environments]
# =============================================================================
# Comma-separated allowlist of front-end origins permitted to send
# credentialed requests. Wildcard `*` is NOT accepted because
# allowCredentials=true; browsers reject Origin:* with credentials.
IGRP_CORS_ALLOWED_ORIGINS=https://app.example.cv,https://portal.example.cv


# =============================================================================
# Session management (Phase B/C — JWT ↔ session binding) [optional]
# =============================================================================
# Absolute session lifetime ceiling (seconds). Default: 8 hours.
IGRP_SESSION_ABSOLUTE_TIMEOUT_SECONDS=28800
# Max concurrent ACTIVE sessions per user across distinct devices.
IGRP_SESSION_MAX_PER_USER=5
# Min interval between last_seen_at heartbeat writes (seconds).
IGRP_SESSION_HEARTBEAT_DEBOUNCE_SECONDS=30
# Bypass SessionEnforcementFilter — only flip to false during a Redis/DB
# outage to avoid a 401-storm forcing every user to re-login.
IGRP_SESSION_ENFORCEMENT_ENABLED=true


# =============================================================================
# Superadmin bootstrap [required]
# =============================================================================
# The internal user-id (UUID) of the superadmin account. The
# DefaultRoleAssignmentBootstrap pins SUPER_ADMIN_ROLE to this user on
# startup so the platform always has at least one super-admin.
IGRP_SUPERADMIN_USER_EXTERNAL_ID=00000000-0000-0000-0000-000000000001
IGRP_SUPERADMIN_EMAIL=superadmin@igrp.cv


# =============================================================================
# User invitation [required]
# =============================================================================
# Public URL of the iGRP App Center — used to build the invitation accept link
# embedded in invitation emails.
IGRP_APP_CENTER_URL=https://app-center.example.cv


# =============================================================================
# File storage [required] — choose 'minio' or 's3'
# =============================================================================
IGRP_STORAGE_PROVIDER=s3
IGRP_STORAGE_SECURITY=false
IGRP_STORAGE_ACCESS_KEY=admin
IGRP_STORAGE_SECRET_KEY=admin12345678
IGRP_STORAGE_BUCKET_NAME=igrp
IGRP_STORAGE_PATH_STYLE_ACCESS=true
IGRP_STORAGE_REGION=praia
# Pre-signed URL TTL (seconds).
IGRP_STORAGE_PRESIGNED_URL_EXPIRATION_TIME=300

# MinIO: provide endpoint host + port separately (the application maps them
# onto igrp.minio.endpoint / igrp.minio.port).
IGRP_STORAGE_ENDPOINT=localhost
IGRP_STORAGE_PORT=9000

# AWS S3: override the full endpoint (protocol + host + port) when targeting
# a non-AWS S3-compatible service. If unset it falls back to
# http://${IGRP_STORAGE_ENDPOINT}:${IGRP_STORAGE_PORT}.
IGRP_S3_AWS_ENDPOINT=http://localhost:9000


# =============================================================================
# Cache (Redis) [required — session enforcement + permission cache]
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
# Leave blank when Redis has no AUTH configured.
REDIS_PASSWORD=


# =============================================================================
# Service discovery (Eureka) [optional — leave disabled outside the IaaS mesh]
# =============================================================================
EUREKA_CLIENT_ENABLED=false
SPRING_CLOUD_DISCOVERY_ENABLED=false
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://igrp-eureka:8761/eureka/


# =============================================================================
# SMTP — outbound notifications [optional]
# =============================================================================
# 'mail' to send via SMTP, 'none' to silently swallow notifications.
IGRP_NOTIFICATIONS_ENABLED=mail

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USERNAME=<smtp_user>
SMTP_PASSWORD=<smtp_password>
# Default From address on outbound emails.
SMTP_SENDER_ID=iam@igrp.cv

# SMTP transport security (maps onto spring.mail.properties.mail.smtp.*).
IGRP_MAIL_SMTP_AUTH=true
IGRP_MAIL_SMTP_STARTTLS_ENABLE=true
IGRP_MAIL_SMTP_STARTTLS_REQUIRED=true

# Email body templates. {{user}} → recipient username, {{url}} → accept link.
IGRP_MAIL_INVITE_TEMPLATE="Hello {{user}}, you were successfully invited to iGRP! Please click on the link below to accept the invitation: {{url}}"
IGRP_MAIL_INVITE_RESPONSE_TEMPLATE="Hello {{user}}, you have successfully accepted the invitation to iGRP!"
IGRP_MAIL_INVITE_CANCELLATION_TEMPLATE="Hello {{user}}, your invitation to the iGRP platform was cancelled. If you have any questions, please contact the administrator."


# =============================================================================
# API documentation (Swagger / OpenAPI) [optional]
# =============================================================================
ENABLE_SWAGGER=true
# When the API is exposed via a gateway prefix, point Swagger UI at the
# gateway-aware paths. Otherwise leave commented out.
SPRINGDOC_SWAGGER_UI_CONFIG_URL=/igrp-access-management/v3/api-docs/swagger-config
SPRINGDOC_SWAGGER_UI_URL=/igrp-access-management/v3/api-docs
# Override the auto-detected server URL Swagger displays in the "Try it out"
# section. Useful when Spring infers the wrong scheme/host behind a proxy.
OPENAPI_SERVER_API=https://api.example.cv/igrp-access-management


# =============================================================================
# Observability (OpenTelemetry → Grafana stack) [optional]
# =============================================================================
# Master toggle. true = ship traces/metrics/logs to OTEL_COLLECTOR_ENDPOINT.
OTEL_DISABLED=false
# OTLP collector endpoint (HTTP). Use the in-cluster service DNS in k8s.
OTEL_HTTP_PORT=4318
OTEL_COLLECTOR_ENDPOINT=http://host.docker.internal:${OTEL_HTTP_PORT}

# The block below is consumed by the docker-compose observability stack
# bundled for local development. Safe to leave at defaults outside compose.
OTEL_ENABLED=true
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_EXPORTER=otlp
OTEL_SERVICE_NAME="${SERVICE_NAME}"

TEMPO_SERVICE_NAME=tempo
TEMPO_SERVICE_HTTP_PORT=3200
TEMPO_SERVICE_ZIPKIN_PORT=9411

PROMETHEUS_SERVICE_NAME=prometheus
PROMETHEUS_SERVICE_PORT=9090

LOKI_SERVICE_NAME=loki
LOKI_SERVICE_PORT=3100

GRAFANA_SERVICE_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=password
GRAFANA_ALLOW_SIGN_UP=false

OTEL_COLLECTOR_SERVICE_NAME=otel-collector
OTEL_PPROF_EXTENSION=1888
OTEL_PROMETHEUS_METRICS_EXPORTER_PORT=8888
OTEL_PROMETHEUS_COLLECTOR_METRICS_EXPORTER_PORT=8889
OTEL_HEALTH_CHECK_PORT=13133
OTEL_GRPC_PORT=4317
OTEL_ZPAGES_PORT=55679
