# --- Build stage ---
FROM ghcr.io/graalvm/native-image-community:21-ol9 AS build

ARG SERVICE_PROFILE
ENV APP_HOME=/app
WORKDIR $APP_HOME

COPY src $APP_HOME/src
COPY pom.xml $APP_HOME

RUN microdnf install -y maven unzip

# Build fat jar
RUN mvn -q -Ptemp clean package -DskipTests

# Unpack fat jar to extract classes + libs
RUN mkdir unpacked && \
    cd unpacked && \
    unzip ../target/access-management-0.0.1-SNAPSHOT.jar && \
    mkdir -p lib && \
    cp -r BOOT-INF/classes . && \
    cp BOOT-INF/lib/*.jar lib/

# Build native image with proper classpath
RUN native-image \
      --no-fallback \
      -cp "unpacked/classes:$(echo unpacked/lib/*.jar | tr ' ' ':')" \
      -H:Name=access-management \
      -H:Class=cv.igrp.platform.access_management.IgrpPlatformAccessManagementApplication \
      -H:+UnlockExperimentalVMOptions \
      -H:ServiceLoaderFeatureExcludeServices=org.hibernate.bytecode.spi.BytecodeProvider \
      -H:ClassInitialization=org.hibernate.validator.internal.engine:build_time \
      -H:+ReportExceptionStackTraces \
      --trace-class-initialization=org.apache.logging.log4j,org.apache.logging.log4j.status,org.apache.logging.log4j.spi,ch.qos.logback.classic,org.jboss.logging,org.apache.commons.logging \
      --trace-class-initialization-to=class-init-trace.log \
      --trace-object-initialization=org.apache.logging.log4j,org.apache.logging.log4j.status,org.apache.logging.log4j.spi,ch.qos.logback.classic,org.jboss.logging,org.apache.commons.logging \
      --initialize-at-run-time=org.apache.logging.log4j,org.apache.logging.log4j.status,org.apache.logging.log4j.spi,ch.qos.logback.classic,org.jboss.logging,org.apache.commons.logging

# --- Runtime stage using scratch ---
FROM scratch

# Set working directory
WORKDIR /app

# Copy native binary from build stage
COPY --from=build /app/target/access-management /app/access-management

# Copy any additional resources your app may need (if any)
# COPY --from=build /app/target/classes /app/classes

# Expose service port
EXPOSE ${SERVICE_PORT}

# Set environment variables
ENV OTEL_SERVICE_NAME=${OTEL_SERVICE_NAME}
ENV OTEL_COLLECTOR_ENDPOINT=${OTEL_COLLECTOR_ENDPOINT}
ENV SPRING_ACTIVE_PROFILE=${SPRING_ACTIVE_PROFILE}

# Run the native binary
ENTRYPOINT ["/app/access-management"]

