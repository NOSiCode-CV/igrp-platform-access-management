# Stage 1: Build with GraalVM and Maven
FROM ghcr.io/graalvm/native-image-community:21-ol9 AS build

# Build arguments
ARG OTEL_TRACES_EXPORTER
ARG OTEL_METRICS_EXPORTER
ARG OTEL_LOGS_EXPORTER
ARG OTEL_COLLECTOR_ENDPOINT
ARG OTEL_SERVICE_NAME
ARG OTEL_ENABLED
ARG SERVICE_PROFILE

# Environment setup
ENV APP_HOME=/app
ENV MAVEN_OPTS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"
WORKDIR $APP_HOME

# Copy only what's needed for build
COPY pom.xml .
COPY src ./src

# Install Maven and build
RUN microdnf install -y maven && \
    mvn -Ptemp clean package -DskipTests && \
    ls -la /app/target && \
    mvn -Ptemp native:compile -DskipTests && \
    ls -la /app/target

# Stage 2: Runtime image
FROM ubuntu:22.04

# Environment variables
ENV OTEL_SERVICE_NAME=${OTEL_SERVICE_NAME}
ENV OTEL_COLLECTOR_ENDPOINT=${OTEL_COLLECTOR_ENDPOINT}
ENV SPRING_ACTIVE_PROFILE=${SPRING_ACTIVE_PROFILE}

# Install minimal dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    libstdc++6 \
    zlib1g \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy native executable
COPY --from=build /app/target/access-management /app/access-management

# Set permissions
RUN chmod +x /app/access-management

EXPOSE ${SERVICE_PORT}
ENTRYPOINT ["/app/access-management"]